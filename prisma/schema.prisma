generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  COMPANY
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(CANDIDATE)
  profile   Profile?
  company   Company?
  createdAt DateTime @default(now())
}

model Profile {
  id           String        @id @default(uuid())
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  birthDate    DateTime?
  description  String?
  desiredRole  String?
    avatarUrl    String?
    phone        String?       
    education    String[]
    experience   String[]
    skills       String[]
  completitud  Int           @default(0)
  applications Application[]
}

model Company {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  nit           String    @unique
  location      String
  coreBusiness  String
  employeeCount Int
  vacancies     Vacancy[]
}

model Vacancy {
  id           String        @id @default(uuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title        String
  description  String
  modality     String        @default("Presencial")
  salaryRange  Int?
    mustHave     String[]
    niceToHave   String[]
    isActive     Boolean       @default(true)
  applications Application[]
  createdAt    DateTime      @default(now())
}

model Application {
  id            String    @id @default(uuid())
  profileId     String
  profile       Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  vacancyId     String
  vacancy       Vacancy   @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  status        String    @default("POSTULADO")
  interviewDate DateTime?
  appliedAt     DateTime  @default(now())
}

model PasswordResetToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}